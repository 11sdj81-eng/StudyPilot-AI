[
  {"id":"rv_definition","display_name":"随机变量定义","concept_id":"random_variable","latex":"X:S\\to\\mathbb{R}","display_text":"X: S → R","symbol_explanation":{"S":"样本空间","X(e)":"样本点 e 对应的实数"},"conditions":"对任意 x，{X≤x} 为事件","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.1"}],"tags":["definition"],"user_visible_text":"随机变量是样本空间到实数的映射。"},
  {"id":"cdf_definition","display_name":"分布函数定义","concept_id":"distribution_function","latex":"F(x)=P\\{X\\le x\\},\\quad -\\infty<x<\\infty","display_text":"F(x) = P{X ≤ x},  -∞ < x < ∞","symbol_explanation":{"F(x)":"分布函数","P{X≤x}":"不超过 x 的累积概率"},"conditions":"x 为任意实数","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.2"}],"tags":["cdf"],"user_visible_text":"F(x) 是随机变量不超过 x 的概率。"},
  {"id":"cdf_properties","display_name":"分布函数三条性质","concept_id":"distribution_function","latex":"\\begin{aligned}&(1)\\ F(x)\\text{ 单调不减}\\\\&(2)\\ 0\\le F(x)\\le 1,\\ F(-\\infty)=0,\\ F(+\\infty)=1\\\\&(3)\\ F(x+0)=F(x)\\text{（右连续）}\\end{aligned}","display_text":"(1) 单调不减 (2) 0≤F(x)≤1, F(-∞)=0, F(+∞)=1 (3) 右连续","symbol_explanation":{},"conditions":"对任意分布函数均需满足","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.2"}],"tags":["cdf","properties"],"user_visible_text":"合法的分布函数必须同时满足这三条性质。"},
  {"id":"pmf_definition","display_name":"分布律（概率质量函数）","concept_id":"discrete_random_variable","latex":"P\\{X=x_k\\}=p_k,\\quad k=1,2,\\dots","display_text":"P{X = xk} = pk,  k = 1,2,...","symbol_explanation":{"xk":"第 k 个取值","pk":"对应概率"},"conditions":"pk ≥ 0 且 ∑pk = 1","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.3"}],"tags":["pmf","discrete"],"user_visible_text":"离散型随机变量的分布由分布律完全确定。"},
  {"id":"pmf_properties","display_name":"分布律性质","concept_id":"discrete_random_variable","latex":"p_k\\ge 0,\\quad \\sum_{k}p_k=1","display_text":"pk ≥ 0,  ∑pk = 1","symbol_explanation":{},"conditions":"所有取值的概率非负且和为 1","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.3"}],"tags":["pmf"],"user_visible_text":"验证分布律合法性只需检查非负性和归一性。"},
  {"id":"pdf_definition","display_name":"概率密度函数定义","concept_id":"continuous_random_variable","latex":"F(x)=\\int_{-\\infty}^{x}f(t)\\,dt","display_text":"F(x) = ∫_{-∞}^{x} f(t) dt","symbol_explanation":{"f(t)":"概率密度函数","积分":"累积概率"},"conditions":"f(x) ≥ 0","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.4"}],"tags":["pdf","continuous"],"user_visible_text":"密度函数的积分等于分布函数。"},
  {"id":"pdf_properties","display_name":"密度函数性质","concept_id":"continuous_random_variable","latex":"f(x)\\ge 0,\\quad \\int_{-\\infty}^{\\infty}f(x)\\,dx=1,\\quad P\\{a<X\\le b\\}=\\int_a^b f(x)\\,dx","display_text":"f(x)≥0; ∫f(x)dx=1; P{a<X≤b}=∫_a^b f(x)dx","symbol_explanation":{},"conditions":"连续型随机变量对任意一点 X=a 有 P{X=a}=0","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.4"}],"tags":["pdf"],"user_visible_text":"密度值 f(a) 不是概率，曲线下面积才是概率。"},
  {"id":"pdf_to_cdf","display_name":"由密度求分布","concept_id":"continuous_random_variable","latex":"F(x)=\\int_{-\\infty}^{x}f(t)\\,dt","display_text":"F(x) = ∫_{-∞}^{x} f(t) dt","symbol_explanation":{},"conditions":"分段积分需注意区间端点","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.4"}],"tags":["pdf","cdf"],"user_visible_text":"由密度函数积分得分布函数，这是连续型随机变量的基本运算。"},
  {"id":"bernoulli_pmf","display_name":"(0-1)分布","concept_id":"common_discrete_distributions","latex":"P\\{X=k\\}=p^k(1-p)^{1-k},\\quad k=0,1","display_text":"P{X=k} = p^k (1-p)^{1-k},  k=0,1","symbol_explanation":{"p":"P{X=1}，成功概率"},"conditions":"只有两个可能结果","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.5"}],"tags":["bernoulli"],"user_visible_text":"(0-1)分布是最简单的两点分布。"},
  {"id":"binomial_pmf","display_name":"二项分布","concept_id":"common_discrete_distributions","latex":"P\\{X=k\\}=C_n^k p^k(1-p)^{n-k},\\quad k=0,1,\\dots,n","display_text":"P{X=k} = C(n,k)·p^k·(1-p)^{n-k},  k=0,1,...,n","symbol_explanation":{"n":"独立重复试验次数","p":"每次成功概率","C(n,k)":"组合数"},"conditions":"n 次独立重复伯努利试验，每次 p 不变","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.5"}],"tags":["binomial"],"user_visible_text":"二项分布 B(n,p) 是最重要的离散分布之一。"},
  {"id":"poisson_pmf","display_name":"泊松分布","concept_id":"common_discrete_distributions","latex":"P\\{X=k\\}=\\frac{\\lambda^k e^{-\\lambda}}{k!},\\quad k=0,1,2,\\dots","display_text":"P{X=k} = λ^k·e^{-λ}/k!,  k=0,1,2,...","symbol_explanation":{"λ":"数学期望（也是方差）"},"conditions":"λ > 0","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.5"}],"tags":["poisson"],"user_visible_text":"泊松分布 P(λ) 描述单位时间/空间内随机事件的发生次数。"},
  {"id":"poisson_approx","display_name":"泊松近似二项","concept_id":"common_discrete_distributions","latex":"C_n^k p^k(1-p)^{n-k}\\approx\\frac{\\lambda^k e^{-\\lambda}}{k!},\\quad \\lambda=np","display_text":"C(n,k)p^k(1-p)^{n-k} ≈ λ^k·e^{-λ}/k!, λ=np","symbol_explanation":{"λ=np":"泊松参数取二项期望"},"conditions":"n 较大、p 较小、λ=np 适中（通常 λ≤10）","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.5"}],"tags":["poisson","approximation"],"user_visible_text":"当 n 大 p 小时可用泊松分布近似二项分布。"},
  {"id":"uniform_pdf","display_name":"均匀分布","concept_id":"common_continuous_distributions","latex":"f(x)=\\begin{cases}\\frac{1}{b-a},&a<x<b\\\\0,&\\text{其他}\\end{cases}","display_text":"f(x)=1/(b-a), a<x<b; 0, 其他","symbol_explanation":{"a,b":"区间端点"},"conditions":"a < b","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.6"}],"tags":["uniform"],"user_visible_text":"均匀分布 U(a,b) 在区间内等可能取值。"},
  {"id":"exponential_pdf","display_name":"指数分布","concept_id":"common_continuous_distributions","latex":"f(x)=\\begin{cases}\\lambda e^{-\\lambda x},&x>0\\\\0,&x\\le 0\\end{cases}","display_text":"f(x)=λe^{-λx}, x>0; 0, x≤0","symbol_explanation":{"λ":"率参数，均值为 1/λ"},"conditions":"λ > 0；具有无记忆性","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.6"}],"tags":["exponential"],"user_visible_text":"指数分布具有无记忆性：P{X>s+t|X>s}=P{X>t}。"},
  {"id":"normal_pdf","display_name":"正态分布密度","concept_id":"common_continuous_distributions","latex":"f(x)=\\frac{1}{\\sqrt{2\\pi}\\sigma}e^{-\\frac{(x-\\mu)^2}{2\\sigma^2}},\\quad -\\infty<x<\\infty","display_text":"f(x)=exp(-(x-μ)²/(2σ²))/(σ√(2π)), -∞<x<∞","symbol_explanation":{"μ":"均值","σ²":"方差","σ":"标准差"},"conditions":"σ > 0","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.6"}],"tags":["normal"],"user_visible_text":"正态分布 N(μ,σ²) 是自然界最常见的连续分布。"},
  {"id":"standard_normal_transform","display_name":"正态标准化变换","concept_id":"common_continuous_distributions","latex":"Z=\\frac{X-\\mu}{\\sigma}\\sim N(0,1)","display_text":"Z = (X-μ)/σ ~ N(0,1)","symbol_explanation":{"Z":"标准正态随机变量","μ":"均值","σ":"标准差"},"conditions":"X ~ N(μ,σ²) 则 Z ~ N(0,1)","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.6"}],"tags":["normal","standardize"],"user_visible_text":"正态→标准化→查表，三步走。"},
  {"id":"cdf_method","display_name":"分布函数法","concept_id":"rv_function_distribution","latex":"F_Y(y)=P\\{Y\\le y\\}=P\\{g(X)\\le y\\}","display_text":"F_Y(y) = P{Y≤y} = P{g(X)≤y}","symbol_explanation":{"g":"变换函数"},"conditions":"从 X 的分布推导 Y=g(X) 的分布","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.7"}],"tags":["transform"],"user_visible_text":"分布函数法是求随机变量函数分布的通用方法。"},
  {"id":"monotonic_transform","display_name":"单调变换公式","concept_id":"rv_function_distribution","latex":"f_Y(y)=f_X(h(y))\\cdot|h'(y)|","display_text":"f_Y(y) = f_X(h(y)) · |h'(y)|","symbol_explanation":{"h(y)":"g 的反函数","h'(y)":"反函数的导数"},"conditions":"y=g(x) 严格单调且可导","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.7"}],"tags":["transform"],"user_visible_text":"单调函数变换可直接套公式，注意绝对值。"},
  {"id":"linear_transform","display_name":"线性变换特例","concept_id":"rv_function_distribution","latex":"Y=aX+b\\ \\Rightarrow\\ f_Y(y)=\\frac{1}{|a|}f_X\\!\\left(\\frac{y-b}{a}\\right)","display_text":"Y=aX+b → f_Y(y)=f_X((y-b)/a)/|a|","symbol_explanation":{"a":"斜率","b":"截距"},"conditions":"a ≠ 0","forbidden_alias":[],"source_refs":[{"source_id":"textbook","file_name":"概率论与随机过程.pdf","page":"§2.7"}],"tags":["transform","linear"],"user_visible_text":"正态分布的线性变换仍为正态分布，这是最重要的特例。"}
]
